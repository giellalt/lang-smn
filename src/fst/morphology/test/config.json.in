{
    "analyser": "@abs_builddir@/../../analyser-gt-norm.hfstol",
    "generator": "@abs_builddir@/../../generator-gt-norm.hfstol",
    "nouns": {
        "lexcfile": "@abs_srcdir@/../stems/nouns.lexc",
        "lemmatags": ["+N+Sg+Nom", "+N+Pl+Nom"],
        "exclusions": ["(ShCmp|RCmpnd|COLL|\\+CmpNP/Suff|\\+Use/MT)"]
    },
    "adjectives": {
        "lexcfile": "@abs_srcdir@/../stems/adjectives.lexc",
        "lemmatags": ["+A+Sg+Nom", "+A+Attr", "+A+Superl+Sg+Nom", "+A+Comp+Sg+Nom"]
    },
    "propernouns": {
        "lexcfile": "@abs_srcdir@/../stems/smn-propernouns.lexc",
        "lemmatags": ["+N+Prop+Sg+Nom", "+N+Prop+Pl+Nom", "+N+Prop+Attr"],
        "exclusions": ["(FirstTag|Proper_infix|\\+Use/MT)"]
    },
    "verbs": {
        "lexcfile": "@abs_srcdir@/../stems/verbs.lexc",
        "lemmatags": ["+V+Inf"],
        "exclusions": ["(LE|IJ|ij\\+V|\\+Use/MT)"]
    }
}
